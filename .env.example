# =============================================================
# XENITH — Variables de entorno
# Copia este archivo a .env para desarrollo local
# En Vercel configura cada variable en Project Settings > Environment Variables
# =============================================================

# ─────────────────────────────────────────────
# BASE DE DATOS (PostgreSQL)
# ─────────────────────────────────────────────

# Desarrollo local (Docker — ver docker-compose.yml)
DATABASE_URL="postgresql://xenith:xenith123@localhost:5432/xenith_db"
DIRECT_URL="postgresql://xenith:xenith123@localhost:5432/xenith_db"

# Producción: usa Neon (https://neon.tech) — crea un proyecto y copia las URLs
# DATABASE_URL usa el pooler (puerto 6432) para serverless/Vercel
# DIRECT_URL usa la conexión directa (puerto 5432) para migraciones
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─────────────────────────────────────────────
# AUTH.JS (NextAuth v5)
# ─────────────────────────────────────────────

# Genera con: openssl rand -base64 32
AUTH_SECRET=""

# En desarrollo:
NEXTAUTH_URL="http://localhost:3000"

# En Vercel: pon la URL de tu deployment (ej: https://xenith.vercel.app)
# Vercel la detecta automáticamente desde VERCEL_URL, pero es bueno ser explícito
# NEXTAUTH_URL="https://tu-dominio.com"

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────

# Misma URL que NEXTAUTH_URL (usada en el cliente)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# En producción: NEXT_PUBLIC_APP_URL="https://tu-dominio.com"

# ─────────────────────────────────────────────
# ADMIN SETUP
# Solo para crear el primer admin via /api/auth/register-admin
# ─────────────────────────────────────────────

# Email y contraseña del primer administrador
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# Genera con: openssl rand -hex 32
# Pasar como header x-setup-key al endpoint de registro
ADMIN_SETUP_KEY=""

# Deshabilita el endpoint una vez creado el admin (pon "true" en producción)
ADMIN_SETUP_DISABLED="false"

# ─────────────────────────────────────────────
# EMAIL (Resend — https://resend.com)
# ─────────────────────────────────────────────

RESEND_API_KEY=""
